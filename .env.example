# ==================================================
# OpenAlfred Configuration
# Copy this file to .env and fill in your values.
# ==================================================

# ──────────────────────────────────
# LLM / AI Settings
# ──────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
CEREBRAS_API_KEY=
GOOGLE_API_KEY=
LANGSMITH_API_KEY=your-langsmith-api-key
TAVILY_API_KEY=tvly-your-tavily-api-key
MEM0_API_KEY=your-mem0-api-key

# ──────────────────────────────────
# Model Configuration
# ──────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
LOCAL_MODEL_NAME=gemma4:e2b
CLOUD_CHAT_MODEL=gpt-5.4-nano
CLOUD_BROWSER_MODEL=gpt-5.4-mini
CEREBRAS_CHAT_MODEL=llama-4-scout
GEMINI_CHAT_MODEL=gemini-3-flash-preview

# ──────────────────────────────────
# LiveKit (Voice / SIP)
# ──────────────────────────────────
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_SIP_TRUNK_ID=ST_Bcj2LDXqL4J7
LIVEKIT_WS_URL=ws://localhost:7880

# ──────────────────────────────────
# TTS (Text-to-Speech)
# ──────────────────────────────────
TTS_URL=http://localhost:7017/v1/audio/speech
TTS_MODEL=tts-1
TTS_VOICE=yingxue
TTS_SAMPLE_RATE=24000
TTS_JITTER_BUFFER_MS=200

# ──────────────────────────────────
# SenseVoice STT (Speech-to-Text)
# ──────────────────────────────────
SENSEVOICE_STT_URL=http://127.0.0.1:8000/extract_text

# ──────────────────────────────────
# Greeting TTS
# ──────────────────────────────────
GREETING_TTS_URL=http://127.0.0.1:10096/tts/stream

# ──────────────────────────────────
# JWT Authentication
# ──────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ──────────────────────────────────
# LangGraph Server
# ──────────────────────────────────
LANGGRAPH_API_URL=http://localhost:2024

# ──────────────────────────────────
# Email
# ──────────────────────────────────
EMAIL_ENCRYPTION_KEY=your-fernet-encryption-key

# ──────────────────────────────────
# Context / Memory Management
# ──────────────────────────────────
MAX_CONTEXT_MESSAGES=20
SUMMARY_THRESHOLD=15
MAX_CONTEXT_TOKENS=6000

# ──────────────────────────────────
# Timezone
# ──────────────────────────────────
TIMEZONE=Europe/London

# ──────────────────────────────────
# Browser Control
# ──────────────────────────────────
CHROME_CDP_URL=http://localhost:9222
# CHROME_USER_DATA_DIR=  (defaults to agent/agent_chrome_profile/)

# ──────────────────────────────────
# Supervisor (Proactive Monitoring)
# ──────────────────────────────────
SUPERVISOR_INTERVAL=600
SUPERVISOR_PHONE_NUMBER=100
SUPERVISOR_OCR_WINDOW_MINS=10

# ──────────────────────────────────
# Screenpipe (Eye Tool)
# ──────────────────────────────────
SCREENPIPE_URL=http://localhost:3030

# ──────────────────────────────────
# Redis (Event Bus)
# ──────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ──────────────────────────────────
# Push Notifications (Bark)
# ──────────────────────────────────
BARK_URL=https://api.day.app/your-bark-device-key
